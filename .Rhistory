View(IPCECUADOR)
summary(IPCECUADOR)
IPCECUADOR.ts <- ts(IPCECUADOR$IPC,
st = c(2005,1),
freq = 12)
plot(IPCECUADOR.ts)
des.IPCECUADOR<-decompose(IPCECUADOR.ts)
sd(des.IPCECUADOR$random,na.rm=TRUE)
#  Frecuencia del componente estacional
des.IPCECUADOR.m$seasonal
des.IPCECUADOR.m<-decompose(IPCECUADOR.ts, type="multiplicative")
plot(des.IPCECUADOR.m)
str(des.IPCECUADOR.m)
#  Frecuencia del componente estacional
des.IPCECUADOR.m$seasonal
plot(des.IPCECUADOR.m$seasonal)
plot(diff(IPCECUADOR.ts))
IPCECUADOR.ts.l <- diff(log(IPCECUADOR.ts))
plot(IPCECUADOR.ts.l)
library(tseries)
# es estacionario? #mi serie IPCECUADOR.TS.L ES ESTACIONARIA SEGUN LA PRUEBA DEL DICKEYFULLER
adf.test(IPCECUADOR.ts.l)
#autocorrelaciÃ›n (original vs rezago),la autocorrelacion desde la primera diferencia ya no tiene relacion con el IPC
acf(IPCECUADOR.ts.l)
#autocorrelaciÃ›n parcial (original vs rezago pero toma en cuenta informaciÃ›n histÃ›rica)
pacf(IPCECUADOR.ts.l)
#autocorrelaciÃ›n parcial (original vs rezago pero toma en cuenta informaciÃ›n histÃ›rica)
pacf(IPCECUADOR.ts.l)
head(IPCECUADOR.ts.l)
#me dice cual es el mejor modelo
ar(IPCECUADOR.ts.l)
library(forecast)
#el orden de integracion cuantas veces  debe ser ARIMA(1,1,1)
auto.arima(IPCECUADOR.ts.l, seasonal = FALSE)
#el orden de integracion cuantas veces  debe ser ARIMA(1,1,1)
auto.arima(IPCECUADOR.ts.l, seasonal = FALSE)
arima(IPCECUADOR.ts.l, order = c(1,0,0))
for(i in 1:10)
{
