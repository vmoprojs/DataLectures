devtools::install_github("vmoprojs/GeoModels-OCL")
#=========================== EVALUATING CORRELATION FUNCTIONS ===========================#
#****************************************************************************************#
#************************************-----SPACE-----*************************************#
#****************************************************************************************#
#=============================== Comp_Cond_Gauss2
rm(list = ls())
library(GeoModels)
library(spam)
# DeviceInfo()
# Define the spatial-coordinates of the points:
set.seed(3)
N=500  # number of location sites
x <- runif(N, 0, 1)
set.seed(6)
y <- runif(N, 0, 1)
coords <- cbind(x,y)
# Define spatial matrix covariates
X=cbind(rep(1,N),runif(N))
# Set the covariance model's parameters:
corrmodel <- "Exp"
mean <- 0.2
mean1 <- -0.5
sill <- 1
nugget <- 0
scale <- 0.2/3
# param<-list(mean=mean,mean1=mean1,sill=sill,nugget=nugget,scale=scale,power1=power1,power2=power2)
CorrParam("Exp")
param<-list(mean=mean,mean1=mean1,sill=sill,nugget=nugget,scale=scale)
# Simulation of the spatial Gaussian RF:
data <- GeoSim(coordx=coords,corrmodel=corrmodel, param=param,X=X)$data
# data <- rnorm(N)
# Fixed parameters
fixed<-list(nugget=nugget,mean1=mean1,sill=sill)
# Starting value for the estimated parameters
# start<-list(mean=mean,mean1=mean1,scale=scale,sill=sill,power1=power1,power2=power2)
start<-list(scale=scale,mean=mean)
# X%*%c(mean,mean1) #means vector
CPUtime = proc.time()
fit1 <- GeoFit(data=data,coordx=coords,corrmodel=corrmodel,
maxdist=0.05,likelihood="Conditional",type="Pairwise",
start=start,fixed=fixed,X=X)
CPUtime = proc.time()-CPUtime;CPUtime
print(fit1)
GPU = 0 # CPU Parallel
local = c(1,1) #First component is 8 if GPU is 0. It is 2^n for n>=0 if GPU is 2
GPUtime1 = proc.time()
fit2 <- GeoFit(data=data,coordx=coords,corrmodel=corrmodel,
maxdist=0.05,likelihood="Conditional",type="Pairwise",
start=start,fixed=fixed,X=X, GPU=GPU, local = local)
GPUtime1 = proc.time()-GPUtime1;GPUtime1
print(fit2)
CPUtime;GPUtime1
GeoModels::DeviceInfo()
