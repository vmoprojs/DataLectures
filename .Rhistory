# ESTE ESTIMA SUPER BIEN LA GNEITING:
#Using data from CompRandFld
# Testing different blocksizes than in V3
# gc()
## see also  https://rdrr.io/rforge/gstat/man/wind.html
## why squared root? http://citeseerx.ist.psu.edu/viewdoc/download?doi=10.1.1.406.4308&rep=rep1&type=pdf
require(mapproj)
require(CompRandFld)
data(irishwinds)
winds.coords <- winds.coords[-3,] #eliminating Rosslare
ntime = 6574
DATA = winds
winds.coords$y = winds.coords[["lat"]]
winds.coords$x = winds.coords[["lon"]]
coordsLONLAT=cbind(winds.coords$x,winds.coords$y)  ## lonlat coordinates
distance="Eucl"
############# sinusoidal projecion
if(distance=="Eucl")
{
P.sinusoidal <- mapproject(coordsLONLAT[,1],coordsLONLAT[,2],projection="sinusoidal")
coords<-cbind(P.sinusoidal$x,P.sinusoidal$y)*6378.388
}
if(distance=="Geod")
{
coords=coordsLONLAT
}
rm(winds,winds.coords)
times = 1:ntime
#**** St: If i need to plot the time series.
# data("wind", package = "gstat")
# wind$time = ISOdate(wind$year+1900, wind$month, wind$day)
# # time series of e.g. Dublin data:
# plot(DUB~time, wind, type= 'l', ylab = "windspeed (knots)", main = "Dub")
#**** End: If i need to plot the time series
dists2 = dist(coords)
dd=max(dists2)*1+0.5
dd1 <- dd
########################################################################
############### Gaussian RF estimation ####################################
model="Gaussian"
nugget = 0
mean=mean(((as.vector(DATA))))
scale_s = .2*dd1
scale_t= .2*max(dist(times))
library(STBEU)
require(MCMCpack)
# ************************************ Double Exponential
model = 1
if (model == 1) {
# exponential model
corrmodel <-"exp_exp"
cc=1
#####
mean=mean
nugget=nugget
scale_s<-scale_s
scale_t<-scale_t
sill=var(((as.vector(DATA))))
param=list(nugget=nugget,mean=mean,scale_t=scale_t,scale_s=scale_s,sill=sill)
fixed=list(nugget = nugget, mean = mean)
fix=c(nugget = nugget, mean = mean)
}
################################################
#   parameters for the subsampling ####
###############################################
coordx=coords[,1]
coordy=coords[,2]
(winc_t=10) #This window size generates 65 time blocks as aprrox. done in simulations
(maxtime=ceiling(.25*winc_t))
(maxdist = dd1)
winstp_t=1 ###   0.5 half overlapping  1 "no" overlapping
if(winc_t<maxtime){
stop("Block length must be greater than maxtime")
}
###############################################
vv = sill
theta=c(mean = mean,sill=vv,scale_s=scale_s,scale_t = scale_t)                #starting value
theta=c(sill=vv,scale_s=scale_s,scale_t = scale_t)                #starting value
weighted=0                                          #weigthed version  1=yes 0=no
### eucliden likelihood ################
type_subs=2   ### type of subsampling  1=in space    2= in time  3 =spacetime
type_dist=1 # Euclidean distance
#*** Pairwise composite likelihood:
start <- as.list(theta)
tCPUComp = proc.time()
fitA <- FitComposite(data=DATA,coordx=coords,coordt=times,
corrmodel=corrmodel,maxtime=maxtime,maxdist=maxdist,
likelihood="Marginal",type="Pairwise",
start=start,fixed=fixed,weighted=F)
