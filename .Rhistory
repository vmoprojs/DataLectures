rm(list = ls())
graphics.off()
datos <- read.csv("varm2.csv", sep = ",")
ts.dat <- ts(datos[,3:5], st = c(2000,1),freq = 4)
names(datos)
library(tseries)
ts.tasas <- diff(log(ts.dat))
pp.test(ts.tasas[,"gdp"])
pp.test(ts.tasas[,"ipc"])
pp.test(ts.tasas[,"m2"])
plot(ts.dat)
plot(ts.tasas)
library(vars)
m.var <- VAR(ts.tasas)
imp.var <- "ipc"
plot(irf(m.var, impulse = imp.var,n.ahead = 3))
plot(irf(m.var,cumulative = TRUE,impulse = imp.var,n.ahead = 3))
predict(m.var, n.ahead = 3)
causality(m.var,cause = "ipc")
causality(m.var,cause = "m2")
causality(m.var,cause = "gdp")
summary(m.var)
