dxt <- diff(ts(rnorm(n, 100, 5)))
dyt <- 0 + 2*dxt+rnorm(n-1)
plot(dyt)
xt<- rep(NA, n-1)
yt<- rep(NA, n-1)
xt[1] <- 0
yt[1] <- 0
for(i in 2:n)
{
xt[i] <- dxt[i] +xt[i-1]
yt[i] <- dyt[i] +yt[i-1]
}
plot(yt, t = "l")
lines(xt)
