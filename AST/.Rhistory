plot(rd.lm, xlab = "", ylab = "", cex = .2)
abline(v = 50)
# Bootstrapping
library(boot)
# Function to run RDDreg_lm for bootstrapping
rd <- function(data, i) {
d <- data[i, ]
r <- RDDdata(y = d$lexptot, x = d$hhland, cutpoint = 50)
d2 <- RDDbw_IK(r)
fit <- RDDreg_np(RDDobject = r, bw = d2)
return(fit$coefficients)
}
boot(hh_98.df, statistic = rd, 1000)
